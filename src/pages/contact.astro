---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import { SITE } from "../consts";

const email = SITE.contactEmail;
const mailto = `mailto:${email}?subject=${encodeURIComponent(
  "Inquiry via donnaweinberger.com"
)}`;

const reasons = [
  { label: "Speaking", note: "Keynotes, panels, fireside chats" },
  { label: "Advisory", note: "Founders, boards, leadership teams" },
  { label: "Press & media", note: "Interviews and commentary" },
  { label: "Partnership", note: "Care, community, and technology" },
];
---

<Layout
  title="Contact"
  path="/contact"
  description="Get in touch with Donna Weinberger for speaking, advisory, press, or partnership inquiries."
>
  <PageHeader
    eyebrow="Contact"
    title="Let's talk."
    intro="Speaking, advisory, press, or partnership — send a note and Donna's team will follow up."
  />

  <section class="section--tight">
    <div class="container contact-layout">
      <aside class="contact-aside" data-reveal>
        <p class="eyebrow">What people reach out about</p>
        <ul class="reason-list">
          {
            reasons.map((r) => (
              <li>
                <span class="reason-label">{r.label}</span>
                <span class="reason-note">{r.note}</span>
              </li>
            ))
          }
        </ul>
        <hr class="spectrum-rule" />
        <p class="aside-note">
          A few sentences about what you're working on and how you'd like to
          collaborate is plenty to get the conversation started.
        </p>
      </aside>

      <div class="contact-main" data-reveal>
        <div class="email-card card">
          <p class="email-eyebrow">Get in touch</p>
          <h2 class="email-title">Email Donna directly</h2>
          <p class="email-copy">
            The fastest way to reach Donna is by email. Click below to open a
            message in your mail app — or copy the address and write whenever
            you're ready.
          </p>

          <a class="btn btn--accent email-btn" href={mailto}>
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="5" width="18" height="14" rx="2" />
              <path d="m3 7 9 6 9-6" />
            </svg>
            Email Donna
          </a>

          <p class="email-address">
            <span class="email-address-label">Or write to</span>
            <a href={mailto}>{email}</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }
  .contact-aside .spectrum-rule {
    margin: 1.75rem 0;
  }
  .reason-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .reason-list li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .reason-label {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--ink);
  }
  .reason-note {
    color: var(--slate);
    font-size: 0.95rem;
  }
  .aside-note {
    color: var(--slate);
    font-size: 0.98rem;
    margin: 0;
  }

  /* Email CTA card */
  .email-card {
    position: relative;
    overflow: hidden;
    padding: clamp(1.75rem, 4vw, 2.75rem);
  }
  .email-card::before {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: var(--spectrum-vert);
  }
  .email-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--slate);
    margin: 0 0 0.75rem;
  }
  .email-title {
    margin: 0 0 0.85rem;
    font-size: clamp(1.6rem, 3vw, 2.1rem);
  }
  .email-copy {
    color: var(--slate);
    margin: 0 0 1.75rem;
    max-width: 34rem;
  }
  .email-btn {
    font-size: 1rem;
    padding: 1rem 1.7rem;
  }
  .email-address {
    margin: 1.5rem 0 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .email-address-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--slate-light);
  }
  .email-address a {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent-ink);
    word-break: break-all;
  }

  @media (max-width: 820px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
