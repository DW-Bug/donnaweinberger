---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ImpactStats from "../components/ImpactStats.astro";
import Timeline from "../components/Timeline.astro";
import { VENTURES } from "../data/ventures";

const featured = VENTURES.slice(0, 4);
---

<Layout
  title="Home"
  path="/"
  description="Donna Weinberger is a founder, executive leader, entrepreneur, and advocate building across behavioral health, nonprofit leadership, technology, community, and AI-enabled innovation."
>
  <Hero />

  <ImpactStats />

  <!-- Featured organizations preview -->
  <section class="section">
    <div class="container">
      <header class="block-head" data-reveal>
        <p class="eyebrow">Selected work</p>
        <h2>Eight ventures, one operating philosophy</h2>
        <p class="lede">
          Start with a real need. Build something affirming and durable around
          it. Then do it again, in the next field that needs it.
        </p>
      </header>

      <div class="feature-grid">
        {
          featured.map((v) => (
            <article class="feature-card card" data-reveal>
              <span class="tag">{v.category}</span>
              <h3>{v.name}</h3>
              <p class="feature-role">{v.role}</p>
              <p class="feature-desc">{v.description}</p>
            </article>
          ))
        }
      </div>

      <div class="block-cta" data-reveal>
        <a href="/organizations" class="btn btn--ghost">View all organizations</a>
      </div>
    </div>
  </section>

  <Timeline />

  <!-- Closing CTA -->
  <section class="section section--dark closing">
    <div class="container narrow">
      <p class="eyebrow" data-reveal>Let's build something</p>
      <h2 data-reveal>
        Speaking, advising, or partnering — the door is open.
      </h2>
      <p class="lede closing-lede" data-reveal>
        Whether you're convening a stage, shaping a program, or starting
        something of your own, Donna brings hard-won perspective across care,
        advocacy, and technology.
      </p>
      <div class="closing-actions" data-reveal>
        <a href="/contact" class="btn btn--accent">Get in touch</a>
        <a href="/speaking" class="btn btn--ghost btn--on-dark">Explore topics</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .block-head {
    max-width: 42rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .feature-card h3 {
    margin: 0.6rem 0 0;
  }
  .feature-card .tag {
    align-self: flex-start;
  }
  .feature-role {
    margin: 0;
    font-weight: 600;
    color: var(--ink-soft);
    font-size: 0.92rem;
  }
  .feature-desc {
    margin: 0.4rem 0 0;
    color: var(--slate);
  }
  .block-cta {
    margin-top: 2.25rem;
  }
  .closing h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }
  .closing-lede {
    color: #cfcbc2;
    margin-bottom: 2rem;
  }
  .closing-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
  .btn--on-dark {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.35);
  }
  .btn--on-dark:hover {
    border-color: #fff;
  }
  @media (max-width: 640px) {
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
