---
import { SITE } from "../consts";
import Portrait from "./Portrait.astro";
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow hero-eyebrow">Founder · Executive · Advocate</p>
      <h1 class="hero-title">
        Building care, community,<br />
        and technology that<br />
        <span class="hero-accent">lasts</span>.
      </h1>
      <p class="lede hero-lede">
        {SITE.name} is a serial founder and executive leader whose work runs from
        affirming behavioral health and nonprofit advocacy to technology and
        AI-enabled innovation — eight organizations, one throughline: people first.
      </p>
      <div class="hero-actions">
        <a href="/organizations" class="btn">See what they've built</a>
        <a href="/speaking" class="btn btn--ghost">Speaking &amp; advisory</a>
      </div>

      <ul class="hero-domains" aria-label="Areas of leadership">
        <li>Behavioral Health</li>
        <li>Nonprofit Leadership</li>
        <li>Technology</li>
        <li>Community</li>
        <li>AI-Enabled Innovation</li>
      </ul>
    </div>

    <div class="hero-figure">
      <div class="hero-portrait-wrap">
        <span class="hero-portrait-bar" aria-hidden="true"></span>
        <Portrait
          class="hero-portrait"
          alt="Donna Weinberger, founder and executive leader"
          loading="eager"
          fetchpriority="high"
          sizes="(max-width: 760px) 70vw, (max-width: 1100px) 40vw, 440px"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem) clamp(3rem, 7vw, 5.5rem);
    overflow: hidden;
  }
  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }
  .hero-eyebrow {
    margin-bottom: 1.5rem;
  }
  .hero-title {
    margin: 0 0 1.6rem;
    font-size: clamp(2.6rem, 6vw, 4.6rem);
    font-weight: 480;
    letter-spacing: -0.02em;
  }
  .hero-accent {
    position: relative;
    background: var(--spectrum);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-style: italic;
  }
  .hero-lede {
    max-width: 36rem;
    margin-bottom: 2.2rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }
  .hero-domains {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 1.4rem 0 0;
    border-top: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .hero-domains li {
    position: relative;
    padding-left: 1rem;
  }
  .hero-domains li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    transform: translateY(-50%);
    background: var(--violet);
  }
  .hero-domains li:nth-child(1)::before { background: var(--coral); }
  .hero-domains li:nth-child(2)::before { background: var(--magenta); }
  .hero-domains li:nth-child(3)::before { background: var(--violet); }
  .hero-domains li:nth-child(4)::before { background: #5b46b4; }
  .hero-domains li:nth-child(5)::before { background: var(--indigo); }

  /* Portrait framing */
  .hero-figure {
    justify-self: end;
    width: 100%;
    max-width: 440px;
  }
  .hero-portrait-wrap {
    position: relative;
    border-radius: var(--radius);
    box-shadow: 0 24px 60px -28px rgba(21, 23, 28, 0.55);
  }
  /* Spectrum accent bar anchored to the portrait's lower-left */
  .hero-portrait-bar {
    position: absolute;
    left: -10px;
    bottom: 28px;
    width: 8px;
    height: 42%;
    border-radius: 8px;
    background: var(--spectrum-vert);
    z-index: 2;
  }
  .hero-figure :global(.hero-portrait img) {
    border: 1px solid var(--line);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 6vw, 3rem);
    }
    .hero-figure {
      order: -1;
      justify-self: start;
      max-width: 300px;
    }
    .hero-portrait-bar {
      height: 36%;
    }
  }
</style>
