---
import { VENTURES } from "../data/ventures";

interface Props {
  heading?: string;
  showIntro?: boolean;
}
const { heading = "Organizations founded", showIntro = true } = Astro.props;
const pad = (n: number) => String(n + 1).padStart(2, "0");
---

<section class="section orgs-section">
  <div class="container">
    {
      showIntro && (
        <header class="orgs-head" data-reveal>
          <p class="eyebrow">{heading}</p>
          <h2>An index of what they've built</h2>
          <p class="lede">
            Eight organizations across care, advocacy, and technology — each
            started to answer a real, specific need.
          </p>
        </header>
      )
    }

    <ol class="orgs-list" role="list">
      {
        VENTURES.map((v, i) => (
          <li class="org" data-reveal>
            <span class="org-num">{pad(i)}</span>
            <div class="org-main">
              <div class="org-titleline">
                <h3 class="org-name">
                  {v.url ? (
                    <a href={v.url} target="_blank" rel="noopener">
                      {v.name}
                    </a>
                  ) : (
                    v.name
                  )}
                </h3>
                {v.status && <span class="org-status">{v.status}</span>}
              </div>
              <p class="org-role">{v.role}</p>
              <p class="org-desc">{v.description}</p>
            </div>
            <span class="org-cat tag">{v.category}</span>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .orgs-head {
    max-width: 42rem;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .orgs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--line);
  }
  .org {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 1.5rem 1.75rem;
    align-items: start;
    padding: clamp(1.6rem, 3vw, 2.2rem) 0;
    border-bottom: 1px solid var(--line);
    transition: background 0.2s ease;
  }
  .org:hover {
    background: color-mix(in srgb, var(--paper-dim) 60%, transparent);
  }
  .org-num {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--violet);
    padding-top: 0.45rem;
    letter-spacing: 0.05em;
  }
  .org-titleline {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    flex-wrap: wrap;
  }
  .org-name {
    margin: 0;
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
  }
  .org-name a {
    color: inherit;
  }
  .org-status {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--indigo);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.2rem 0.5rem;
  }
  .org-role {
    margin: 0.35rem 0 0.6rem;
    font-weight: 600;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .org-desc {
    margin: 0;
    color: var(--slate);
    max-width: 44rem;
  }
  .org-cat {
    justify-self: end;
    white-space: nowrap;
  }
  @media (max-width: 760px) {
    .org {
      grid-template-columns: 40px 1fr;
    }
    .org-cat {
      grid-column: 2;
      justify-self: start;
      margin-top: 0.25rem;
    }
  }
</style>
