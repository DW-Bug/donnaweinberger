---
const stats = [
  { figure: "8", label: "Organizations founded", note: "Across five domains" },
  { figure: "5", label: "Fields of leadership", note: "Health · Nonprofit · Tech · Community · AI" },
  { figure: "1", label: "Statewide honor", note: "Equality Florida Voice for Equality" },
  { figure: "∞", label: "People-first mandate", note: "The throughline in every venture" },
];
---

<section class="impact section section--dark">
  <div class="container">
    <p class="eyebrow" data-reveal>Impact at a glance</p>
    <div class="impact-grid">
      {
        stats.map((s) => (
          <div class="impact-item" data-reveal>
            <span class="impact-figure">{s.figure}</span>
            <span class="impact-label">{s.label}</span>
            <span class="impact-note">{s.note}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }
  .impact-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 1.25rem;
    border-top: 2px solid transparent;
    border-image: var(--spectrum) 1;
  }
  .impact-figure {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    line-height: 1;
    color: #fdfcfa;
  }
  .impact-label {
    font-weight: 600;
    color: #e7e4dd;
    font-size: 1.02rem;
  }
  .impact-note {
    font-size: 0.85rem;
    color: #9b968d;
  }
  @media (max-width: 760px) {
    .impact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 420px) {
    .impact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
