---
interface Props {
  eyebrow: string;
  title: string;
  intro?: string;
}
const { eyebrow, title, intro } = Astro.props;
---

<header class="page-header">
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    {intro && <p class="lede page-intro">{intro}</p>}
  </div>
</header>

<style>
  .page-header {
    padding-block: clamp(2.75rem, 7vw, 5rem) clamp(1.5rem, 3vw, 2.5rem);
  }
  .page-header h1 {
    font-size: clamp(2.3rem, 5.5vw, 3.8rem);
    margin-bottom: 1rem;
  }
  .page-intro {
    max-width: 42rem;
  }
</style>
